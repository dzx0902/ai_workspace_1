# Runtime mode
APP_ENV=production
WORKSPACE_ROOT=/opt/ai_workspace

# LLM provider
LLM_PROVIDER=deepseek
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# DeepSeek
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=bge-m3

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=learning_docs

# Embeddings
EMBED_PROVIDER=local
EMBED_MODEL=/opt/models/bge-small-zh-v1.5
EMBED_DEVICE=cpu

# Workspace paths
INPUT_ROOT=/opt/ai_workspace/input
UPLOADS_ROOT=/opt/ai_workspace/uploads
PROCESSED_ROOT=/opt/ai_workspace/processed
PROCESSED_MD=/opt/ai_workspace/processed/markdown
PROCESSED_TRANSCRIPTS=/opt/ai_workspace/processed/transcripts
PROCESSED_JSON=/opt/ai_workspace/processed/json
NOTES_ROOT=/opt/ai_workspace/notes
READ_REPOS_ROOT=/opt/ai_workspace/repos/allowed
REPOS_ROOT=/opt/ai_workspace/repos/allowed
WRITE_REPOS_ROOT=/opt/ai_workspace/repos/allowed
TASKS_ROOT=/opt/ai_workspace/tasks
KB_DIR=/opt/ai_workspace/kb
LOG_DIR=/opt/ai_workspace/logs

# Obsidian export paths
OBSIDIAN_VAULT=/opt/obsidian
OBSIDIAN_AI_ROOT=/opt/obsidian/AI
OBSIDIAN_OUT=/opt/obsidian/AI

# Optional OpenReview credentials
PAPER_RADAR_OPENREVIEW_USERNAME=
PAPER_RADAR_OPENREVIEW_PASSWORD=
PAPER_RADAR_OPENREVIEW_TOKEN=
PAPER_RADAR_OPENREVIEW_TOKEN_EXPIRES_IN=
