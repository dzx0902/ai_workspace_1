PAPER_RADAR_LLM_PROVIDER=deepseek
PAPER_RADAR_LLM_TIMEOUT=60
PAPER_RADAR_LLM_MAX_RETRIES=3
PAPER_RADAR_STRONG_MODEL=
PAPER_RADAR_CHEAP_MODEL=
PAPER_RADAR_INPUT_COST_PER_M=0
PAPER_RADAR_OUTPUT_COST_PER_M=0
PAPER_RADAR_STRONG_INPUT_COST_PER_M=0
PAPER_RADAR_STRONG_OUTPUT_COST_PER_M=0

# Chroma / embedding
CHROMA_HOST=localhost
CHROMA_PORT=8000
PAPER_RADAR_CHROMA_COLLECTION=paper_radar
PAPER_RADAR_EMBED_PROVIDER=local
PAPER_RADAR_EMBED_MODEL=/mnt/f/AIModels/bge-small-zh-v1.5
PAPER_RADAR_EMBED_DEVICE=cpu
OLLAMA_BASE_URL=http://127.0.0.1:11434

# PubMed / NCBI E-utilities (API key is optional)
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=paper_radar

# OpenReview (for long-running jobs, username/password lets Paper Radar refresh tokens)
PAPER_RADAR_OPENREVIEW_USERNAME=
PAPER_RADAR_OPENREVIEW_PASSWORD=
PAPER_RADAR_OPENREVIEW_TOKEN=
PAPER_RADAR_OPENREVIEW_TOKEN_EXPIRES_IN=604800

# Generic OpenAI-compatible provider (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Existing ai_workspace provider variables are also supported:
# DEEPSEEK_API_KEY, DEEPSEEK_BASE_URL, DEEPSEEK_MODEL
# DASHSCOPE_API_KEY, DASHSCOPE_BASE_URL, DASHSCOPE_MODEL
# SILICONFLOW_API_KEY, SILICONFLOW_BASE_URL, SILICONFLOW_MODEL
